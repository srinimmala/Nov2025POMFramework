<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="Open Cart Test Regression Suite" verbose="3"
	parallel="tests" thread-count="3">


    <listeners>
		<listener class-name="com.aventstack.chaintest.plugins.ChainTestListener" />
		<listener class-name="com.opencart.qa.listeners.TestAllureListener" />
		<listener class-name="com.opencart.qa.listeners.AnnotationTransformer" />
	</listeners>


	<test name="Login Page Test">
		<parameter name="browser" value="chrome" />

		<classes>
			<class name="com.opencart.qa.tests.LoginPageTest" />
		</classes>
	</test>


